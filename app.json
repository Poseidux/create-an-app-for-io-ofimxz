{
  "expo": {
    "name": "Chroniqo Stopwatches",
    "slug": "chroniqo-stopwatches",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/9217b728-5aad-427c-8a0f-459f53b19344.png",
