    "splash": {
      "image": "./assets/images/9217b728-5aad-427c-8a0f-459f53b19344.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.poseiduxfitness.chroniqo",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "splash": {
        "image": "./assets/images/9217b728-5aad-427c-8a0f-459f53b19344.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.poseiduxfitness.chroniqo.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
